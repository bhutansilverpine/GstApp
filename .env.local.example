# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase Database
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini AI
GEMINI_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# RMA Payment Gateway
RMA_PAYMENT_API_KEY=rma_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RMA_PAYMENT_SECRET=rma_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RMA_MERCHANT_ID=merchant_xxxxxxxxxxxxxx
NEXT_PUBLIC_RMA_MERCHANT_ID=merchant_xxxxxxxxxxxxxx

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Silverpine Ledger

# Feature Flags
NEXT_PUBLIC_ENABLE_SIGN_UP=true
NEXT_PUBLIC_ENABLE_BANK_STATEMENT_UPLOAD=true
NEXT_PUBLIC_ENABLE_RECEIPT_SCAN=true
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=10

# Database (Drizzle ORM)
DATABASE_URL=postgresql://user:password@localhost:5432/silverpine_ledger

# Node Environment
NODE_ENV=development

# ====================================================================
# PRODUCTION DEPLOYMENT NOTES
# ====================================================================
#
# When deploying to production (Vercel):
#
# 1. Update NEXT_PUBLIC_APP_URL to your production URL
#    - Example: NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
#
# 2. Use production API keys for all services:
#    - Clerk: Use production keys (sk_live_*) instead of test keys
#    - Supabase: Use production project credentials
#    - RMA Payment: Use live payment gateway credentials
#    - Gemini AI: Use production API key
#
# 3. Security Requirements:
#    - Never commit .env.local or any environment files with real keys
#    - Always use environment variables in Vercel dashboard
#    - Rotate keys if they are ever accidentally exposed
#    - Use strong, unique passwords for database connections
#
# 4. Database Configuration:
#    - Use a managed PostgreSQL service (Supabase/Neon/Railway)
#    - Enable connection pooling for production
#    - Set up read replicas for high-traffic scenarios
#    - Configure automated backups
#
# 5. Feature Flags:
#    - Set NEXT_PUBLIC_ENABLE_SIGN_UP=false if you want to control user onboarding
#    - Adjust upload limits based on your hosting plan
#    - Test all features in staging before enabling in production
#
# 6. Monitoring & Logging:
#    - Set up error tracking (Sentry, LogRocket, etc.)
#    - Configure analytics (Google Analytics, Plausible, etc.)
#    - Enable performance monitoring
#
# For Vercel deployment, add these variables in your Vercel project settings:
# https://vercel.com/docs/concepts/projects/environment-variables
