# Database Configuration
DATABASE_URL="postgresql://user:password@host:port/database"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxx"
CLERK_SECRET_KEY="sk_test_xxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Application Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Silverpine Ledger"

# AI/OCR Services (Optional - for receipt extraction)
# OPENAI_API_KEY="sk-xxxxx"
# GOOGLE_CLOUD_VISION_API_KEY="xxxxx"

# File Storage (Optional - for receipt images)
# AWS_S3_BUCKET="silverpine-receipts"
# AWS_ACCESS_KEY_ID="xxxxx"
# AWS_SECRET_ACCESS_KEY="xxxxx"
# AWS_REGION="us-east-1"

# Email Configuration (Optional)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"

# Feature Flags
NEXT_PUBLIC_ENABLE_RECEIPT_AI="true"
NEXT_PUBLIC_ENABLE_BANK_IMPORT="true"